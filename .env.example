# Get a free API key at https://hunter.io (sign up, then API keys in dashboard).
HUNTER_API_KEY=your_api_key_here

# Database URL (PostgreSQL for production, leave empty for local SQLite)
# Get this from Supabase: Project Settings > Database > Connection string (URI)
DATABASE_URL=

# Supabase Auth - Backend JWT verification
# Get this from Supabase: Project Settings > API > JWT Secret
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# Frontend environment variables (also add to frontend/.env.local)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
