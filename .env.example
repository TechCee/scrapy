# Get a free API key at https://hunter.io (sign up, then API keys in dashboard).
# Add this to .env (copy: cp .env.example .env) and set your key.
HUNTER_API_KEY=your_api_key_here

# Portal authentication credentials
PORTAL_USERNAME=admin
PORTAL_PASSWORD=your_secure_password_here

# Database URL (PostgreSQL for production, leave empty for local SQLite)
# Format: postgresql://user:password@host:port/database
# Example from Supabase: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=
